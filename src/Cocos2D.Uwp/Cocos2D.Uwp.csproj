<?xml version="1.0" encoding="utf-8"?>
<!--
  Cocos2D.Uwp.csproj — source of the Cocos2D-Mono.Uwp NuGet package
  (continuation of NuGet versions 2.4.7.x → 2.4.8.3 published Jan 2025).

  This is the legacy pre-SDK MSBuild format because UWP class libraries
  require TargetPlatformIdentifier=UAP, which the modern SDK-style csproj
  format does not support cleanly.

  Source is consumed from a git submodule pinned to a specific mainline
  cocos2d-mono commit — see ../../external/cocos2d-mono. The pin commit
  predates the upcoming Phase 2 deletion of #if NETFX_CORE blocks, so this
  repo's build is unaffected by mainline modernization.
-->
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{11382845-C53D-4D81-8F2E-A7F88C9BDAD6}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>Cocos2D</RootNamespace>
    <AssemblyName>Cocos2D</AssemblyName>
    <DefaultLanguage>en-US</DefaultLanguage>
    <TargetPlatformIdentifier>UAP</TargetPlatformIdentifier>
    <!-- Lowered from 10.0.20348.0 (historical mainline value) to 10.0.19041.0
         because the GitHub Actions windows-2022 image's VS 2022 Universal
         workload installs the UAP platform extension for 10.0.19041 but not
         10.0.20348. UAP.props for 10.0.20348 is missing on the runner ->
         error APPX3217. 10.0.19041 is Win10 20H1, well past our
         TargetPlatformMinVersion of 10.0.16299. -->
    <TargetPlatformVersion Condition=" '$(TargetPlatformVersion)' == '' ">10.0.19041.0</TargetPlatformVersion>
    <TargetPlatformMinVersion>10.0.16299.0</TargetPlatformMinVersion>
    <MinimumVisualStudioVersion>14</MinimumVisualStudioVersion>
    <FileAlignment>512</FileAlignment>
    <ProjectTypeGuids>{A5A43C5B-DE2A-4C0C-9213-0A381AF9435A};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
  </PropertyGroup>

  <!-- ============================================================
       Source root: mainline cocos2d-mono via submodule
       ============================================================ -->
  <PropertyGroup>
    <Cocos2DMonoRoot>..\..\external\cocos2d-mono\</Cocos2DMonoRoot>
    <Cocos2DSourceRoot>$(Cocos2DMonoRoot)cocos2d\</Cocos2DSourceRoot>
  </PropertyGroup>

  <!-- ============================================================
       Per-architecture configurations (required for UWP / .NET Native)
       ============================================================ -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Uwp\Debug\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\Debug</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\Debug</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;DEBUG;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Uwp\Release\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\Release</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\Release</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseDotNetNativeToolchain>true</UseDotNetNativeToolchain>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x86'">
    <PlatformTarget>x86</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <OutputPath>bin\Uwp\x86\Debug\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\x86\Debug</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\x86\Debug</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;DEBUG;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <NoWarn>;2008</NoWarn>
    <DebugType>full</DebugType>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
    <PlatformTarget>x86</PlatformTarget>
    <OutputPath>bin\Uwp\x86\Release\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\x86\Release</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\x86\Release</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <Optimize>true</Optimize>
    <NoWarn>;2008</NoWarn>
    <DebugType>pdbonly</DebugType>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseDotNetNativeToolchain>true</UseDotNetNativeToolchain>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|ARM'">
    <PlatformTarget>ARM</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <OutputPath>bin\Uwp\ARM\Debug\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\ARM\Debug</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\ARM\Debug</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;DEBUG;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <NoWarn>;2008</NoWarn>
    <DebugType>full</DebugType>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|ARM'">
    <PlatformTarget>ARM</PlatformTarget>
    <OutputPath>bin\Uwp\ARM\Release\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\ARM\Release</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\ARM\Release</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <Optimize>true</Optimize>
    <NoWarn>;2008</NoWarn>
    <DebugType>pdbonly</DebugType>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseDotNetNativeToolchain>true</UseDotNetNativeToolchain>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <PlatformTarget>x64</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <OutputPath>bin\Uwp\x64\Debug\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\x64\Debug</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\x64\Debug</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;DEBUG;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <NoWarn>;2008</NoWarn>
    <DebugType>full</DebugType>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x64'">
    <PlatformTarget>x64</PlatformTarget>
    <OutputPath>bin\Uwp\x64\Release\</OutputPath>
    <IntermediateOutputPath>obj\Uwp\x64\Release</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\Uwp\x64\Release</BaseIntermediateOutputPath>
    <DefineConstants>TRACE;NETFX_CORE;WINDOWS_UWP;WINDOWS</DefineConstants>
    <Optimize>true</Optimize>
    <NoWarn>;2008</NoWarn>
    <DebugType>pdbonly</DebugType>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseDotNetNativeToolchain>true</UseDotNetNativeToolchain>
  </PropertyGroup>

  <PropertyGroup>
    <RestoreProjectStyle>PackageReference</RestoreProjectStyle>
  </PropertyGroup>

  <!-- ============================================================
       Compile sources from the mainline submodule
       ============================================================ -->
  <ItemGroup>
    <Compile Include="Properties\AssemblyInfo.cs" />

    <!--
      Glob the entire shared cocos2d tree from the submodule. Exclusions:
        bin/ obj/                       - build artifacts
        cocos2d.* / cocos2d.Core.*      - mainline per-platform csproj folders
        external lib/**                 - vendored ICSharpCode (never compiled by mainline either)
        Properties/AssemblyInfo*.cs     - local copy supplied by this project
        platform/Tuple.cs               - dead #if WINDOWS_PHONE || XBOX360 file
    -->
    <Compile Include="$(Cocos2DSourceRoot)**\*.cs"
             Exclude="$(Cocos2DSourceRoot)bin\**;$(Cocos2DSourceRoot)obj\**;$(Cocos2DSourceRoot)cocos2d.*\**;$(Cocos2DSourceRoot)cocos2d.Core.*\**;$(Cocos2DSourceRoot)external lib\**;$(Cocos2DSourceRoot)Properties\AssemblyInfo*.cs;$(Cocos2DSourceRoot)platform\Tuple.cs" />
  </ItemGroup>

  <!-- ============================================================
       Package references — pinned to last UWP-supporting versions
       ============================================================ -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NETCore.UniversalWindowsPlatform">
      <Version>6.2.11</Version>
    </PackageReference>
    <PackageReference Include="MonoGame.Framework.WindowsUniversal" Version="3.8.1.303" />
    <PackageReference Include="MonoGame.Content.Builder.Task" Version="3.8.1.303" />
    <PackageReference Include="SharpDX.Mathematics">
      <Version>4.0.1</Version>
    </PackageReference>
    <PackageReference Include="SharpZipLib">
      <Version>1.3.3</Version>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Box2D.Uwp\Box2D.Uwp.csproj">
      <Project>{ACAC14A0-8C2B-413C-875F-A2AD3C647800}</Project>
      <Name>Box2D.Uwp</Name>
    </ProjectReference>
  </ItemGroup>

  <PropertyGroup Condition=" '$(VisualStudioVersion)' == '' or '$(VisualStudioVersion)' &lt; '14.0' ">
    <VisualStudioVersion>14.0</VisualStudioVersion>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WindowsXaml\v$(VisualStudioVersion)\Microsoft.Windows.UI.Xaml.CSharp.targets" />

</Project>

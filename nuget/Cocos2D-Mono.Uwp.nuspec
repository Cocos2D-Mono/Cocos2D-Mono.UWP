<?xml version="1.0"?>
<package>
  <metadata>
    <id>Cocos2D-Mono.Uwp</id>
    <version>2.4.8.4</version>
    <title>cocos2d-mono for UWP</title>
    <authors>Cocos2D-Mono Team, Broken Walls Studios</authors>
    <owners>Cocos2D-Mono Team, Broken Walls Studios</owners>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/Cocos2D-Mono/cocos2d-mono-uwp</projectUrl>
    <iconUrl>https://pbs.twimg.com/profile_images/1112234186457473024/G7S7ARjA_400x400.png</iconUrl>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <description>Cocos2D-Mono for UWP (Windows Universal Platform / Xbox UWP). Maintained from the cocos2d-mono-uwp repository; cocos2d-mono source is pinned via git submodule.</description>
    <repository url="https://github.com/Cocos2D-Mono/cocos2d-mono-uwp" type="git" />
    <releaseNotes>
- Cocos2D-Mono.Uwp moved to its own repository (cocos2d-mono-uwp).
- cocos2d-mono source is consumed via a pinned git submodule (mainline commit c30f5ec3 — the last commit with full #if NETFX_CORE source intact).
- MonoGame.Framework.WindowsUniversal pinned to 3.8.2.1105 (final UWP release).
- Continues the version line from 2.4.8.3 (Jan 14, 2025).
    </releaseNotes>
    <copyright>Copyright © 2026 Cocos2D-Mono Team; Broken Walls Studios, LLC.</copyright>
    <tags>mono monogame cocos2d game uwp xbox windows-universal</tags>
    <dependencies>
      <dependency id="Microsoft.NETCore.UniversalWindowsPlatform" version="6.2.11" />
      <dependency id="MonoGame.Framework.WindowsUniversal" version="3.8.2.1105" />
      <dependency id="MonoGame.Content.Builder.Task" version="3.8.2.1105" />
      <dependency id="SharpDX.Mathematics" version="4.0.1" />
      <dependency id="SharpZipLib" version="1.3.3" />
      <dependency id="Cocos2D-Mono.Box2D.Uwp" version="2.4.8.4" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\src\Cocos2D.Uwp\bin\Uwp\Release\*.dll" target="lib\netcore" />
    <file src="..\src\Cocos2D.Uwp\bin\Uwp\Release\*.pri" target="lib\netcore" />
    <file src="..\src\Cocos2D.Uwp\bin\Uwp\Release\Cocos2D\**" target="lib\netcore\Cocos2D" />
  </files>
</package>
